.page { min-height: 100vh; background: #FFFAF7; }

/* 作业卡片 */
.hw-list { padding: 0 30rpx 30rpx; }
.hw-card {
  background: #FFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.hw-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.hw-subject { display: flex; align-items: center; }
.subject-text { font-size: 32rpx; font-weight: bold; margin-right: 12rpx; }
.hw-type { font-size: 22rpx !important; }

.hw-status { font-size: 24rpx !important; padding: 6rpx 16rpx !important; }
.hw-status.pending { background: #FFF3E0; color: #F39C12; }
.hw-status.graded { background: #EEF2FF; color: #5B7FFF; }
.hw-status.done { background: #E8F8E8; color: #27AE60; }

.hw-date { font-size: 24rpx; color: #BBB; display: block; margin-top: 10rpx; }

.hw-score { margin-top: 12rpx; }
.score-label { font-size: 24rpx; color: #999; }
.score-value { font-size: 28rpx; color: #F39C12; font-weight: bold; }
.score-accuracy { font-size: 24rpx; color: #27AE60; }
.score-errors { font-size: 24rpx; color: #E74C3C; }

/* 照片 */
.hw-photos { margin-top: 16rpx; }
.photo-group { margin-bottom: 12rpx; }
.photo-step-label { font-size: 24rpx; color: #999; display: block; margin-bottom: 8rpx; }
.photo-thumbs { display: flex; flex-wrap: wrap; gap: 8rpx; }
.thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #F5F5F5;
}

/* 备注 */
.hw-remark {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 2rpx solid #ECEFF5;
  line-height: 1.5;
}
