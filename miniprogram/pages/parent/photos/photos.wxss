.page { min-height: 100vh; background: #FFFAF7; }

/* 头部 */
.header {
  padding: 24rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.header-name { font-size: 36rpx; font-weight: bold; color: #333; }
.header-count { font-size: 26rpx; color: #999; }

/* 照片墙 — 瀑布流风格 */
.photo-wall {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx;
  gap: 16rpx;
}

.photo-item {
  width: calc(33.33% - 12rpx);
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  background: #FFF;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.photo-image {
  width: 100%;
  height: 280rpx;
  display: block;
  background: #EEE;
}

/* 类型标签角标 */
.photo-overlay {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
}
.photo-type { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 8rpx; }

/* 日期 */
.photo-date {
  display: block;
  font-size: 22rpx;
  color: #999;
  padding: 8rpx 10rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 全屏预览 */
.preview-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.95);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}
.preview-mask.show {
  opacity: 1;
  pointer-events: auto;
}
.preview-header {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 80rpx 30rpx 30rpx;
  display: flex;
  justify-content: flex-end;
}
.preview-header { justify-content: space-between; }
.preview-close, .preview-download {
  font-size: 28rpx;
  color: #FFF;
  padding: 16rpx 28rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 40rpx;
}
.preview-download { background: rgba(91,127,255,0.7); }
.preview-image {
  width: 100%;
  max-height: 70vh;
}
.preview-remark {
  color: #FFF;
  font-size: 28rpx;
  max-width: 80%;
  text-align: center;
  margin-top: 30rpx;
  line-height: 1.6;
}
