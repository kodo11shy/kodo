.page {
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  background: #FF8C5A;
}
.login-container {
  width: 85%;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 60rpx 50rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
}
.login-header { text-align: center; margin-bottom: 50rpx; }
.login-icon { font-size: 80rpx; }
.login-title { font-size: 40rpx; font-weight: bold; color: #333; margin-top: 20rpx; display: block; }
.login-desc { font-size: 26rpx; color: #999; margin-top: 10rpx; display: block; }
.input-group {
  background: #F8F8F8;
  border-radius: 12rpx;
  border: 2rpx solid #E8E8E8;
  padding: 0 30rpx;
}
.code-input { height: 90rpx; font-size: 32rpx; color: #333; text-align: center; letter-spacing: 8rpx; }
.code-input-sub { height: 70rpx; font-size: 26rpx; letter-spacing: 2rpx; }
.error-msg { color: #E74C3C; font-size: 26rpx; margin-top: 16rpx; text-align: center; }
.login-btn { margin-top: 40rpx; height: 90rpx; line-height: 90rpx; }
.tip-text { font-size: 24rpx; color: #999; display: block; }
.login-footer { text-align: center; margin-top: 40rpx; }
.back-link { font-size: 26rpx; color: #999; text-decoration: underline; }
