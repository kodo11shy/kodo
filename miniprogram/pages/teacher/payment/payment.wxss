.page {
  min-height: 100vh;
  background: #F7F8FC;
  padding-bottom: 40rpx;
}

.month-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
}

.month-picker {
  min-width: 220rpx;
  height: 76rpx;
  border-radius: 14rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 14rpx rgba(45, 62, 92, 0.04);
}

.month-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #2F3A4C;
  margin-right: 10rpx;
}

.add-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border: none;
  border-radius: 14rpx;
  font-size: 27rpx;
  background: #5B7FFF;
  color: #FFFFFF;
}

.summary-card,
.todo-card {
  margin: 0 24rpx 18rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 18rpx rgba(45, 62, 92, 0.06);
}

.summary-title,
.todo-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #2F3A4C;
}

.summary-subtitle {
  display: block;
  font-size: 23rpx;
  color: #8B94A7;
  margin-top: 6rpx;
}

.amount-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 22rpx;
}

.amount-main {
  background: #F7FAFF;
  border-radius: 12rpx;
  padding: 18rpx 8rpx;
  text-align: center;
  min-width: 0;
}

.amount-label {
  display: block;
  font-size: 22rpx;
  color: #8B94A7;
}

.amount-value {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  margin-top: 8rpx;
  color: #2F3A4C;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.amount-value.total {
  color: #5B7FFF;
}

.amount-value.paid,
.bill-value.paid {
  color: #35A86B;
}

.amount-value.unpaid,
.bill-value.unpaid {
  color: #E65F5C;
}

.people-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-top: 16rpx;
}

.people-item {
  text-align: center;
  color: #8B94A7;
  font-size: 22rpx;
  background: #FAFBFE;
  border-radius: 10rpx;
  padding: 12rpx 4rpx;
}

.people-num {
  display: block;
  color: #2F3A4C;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.todo-head,
.todo-row,
.student-row,
.name-row,
.card-actions {
  display: flex;
  align-items: center;
}

.todo-head,
.todo-row,
.name-row,
.card-actions {
  justify-content: space-between;
}

.todo-count {
  color: #FF8C42;
  background: #FFF4EA;
  border-radius: 999rpx;
  padding: 6rpx 18rpx;
  font-size: 24rpx;
}

.todo-row {
  padding: 18rpx 0 0;
}

.todo-name {
  display: block;
  font-size: 26rpx;
  color: #2F3A4C;
  font-weight: 700;
}

.todo-desc {
  display: block;
  font-size: 23rpx;
  color: #8B94A7;
  margin-top: 4rpx;
}

.todo-action {
  color: #5B7FFF;
  border: 2rpx solid #CFE5FF;
  background: #EEF6FF;
  border-radius: 999rpx;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  flex-shrink: 0;
}

.todo-empty {
  margin-top: 18rpx;
  font-size: 25rpx;
  color: #7FA58E;
  background: #F0FAF4;
  border-radius: 12rpx;
  padding: 18rpx;
}

.filter-scroll {
  white-space: nowrap;
  margin: 0 24rpx 18rpx;
}

.filter-row {
  display: inline-flex;
  gap: 12rpx;
  min-width: 100%;
}

.filter-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: #697386;
  font-size: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(45, 62, 92, 0.04);
}

.filter-chip.active {
  background: #5B7FFF;
  color: #FFFFFF;
}

.filter-count {
  font-size: 22rpx;
  opacity: 0.82;
}

.payment-list {
  padding: 0 24rpx;
}

.payment-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 22rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 5rpx 16rpx rgba(45, 62, 92, 0.055);
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #EAF2FF;
  color: #5B7FFF;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.student-info {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.student-name {
  font-size: 29rpx;
  font-weight: 700;
  color: #2F3A4C;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.student-detail {
  display: block;
  font-size: 23rpx;
  color: #8B94A7;
  margin-top: 4rpx;
}

.status-tag {
  flex-shrink: 0;
  font-size: 22rpx;
  border-radius: 999rpx;
  padding: 5rpx 14rpx;
}

.tag-ok {
  color: #35A86B;
  background: #ECF8F1;
}

.tag-warn {
  color: #FF8C42;
  background: #FFF4EA;
}

.tag-danger {
  color: #E65F5C;
  background: #FFF0F0;
}

.tag-muted {
  color: #7B8496;
  background: #F0F2F6;
}

.bill-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 18rpx;
}

.bill-item {
  background: #FAFBFE;
  border-radius: 10rpx;
  padding: 14rpx 8rpx;
  text-align: center;
  min-width: 0;
}

.bill-label {
  display: block;
  font-size: 21rpx;
  color: #9AA3B5;
}

.bill-value {
  display: block;
  color: #2F3A4C;
  font-size: 27rpx;
  font-weight: 700;
  margin-top: 5rpx;
}

.fee-line {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
  color: #8B94A7;
  font-size: 23rpx;
  margin-top: 16rpx;
}

.fee-line text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-actions {
  margin-top: 18rpx;
}

.action-btn {
  margin-left: auto;
  color: #5B7FFF;
  background: #EEF6FF;
  border: 2rpx solid #CFE5FF;
  border-radius: 999rpx;
  font-size: 24rpx;
  padding: 8rpx 22rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
  display: block;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.half {
  flex: 1;
  min-width: 0;
}

.picker-field {
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  border: 2rpx solid #E8E8E8;
  box-sizing: border-box;
}

.loading-container {
  padding: 80rpx 0;
  text-align: center;
  color: #8B94A7;
  font-size: 26rpx;
}

.empty-state {
  padding: 70rpx 30rpx;
  text-align: center;
  color: #8B94A7;
}

.empty-image {
  width: 220rpx;
  height: 180rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #596276;
}

.empty-desc {
  display: block;
  font-size: 24rpx;
  color: #9AA3B5;
  margin-top: 8rpx;
}
