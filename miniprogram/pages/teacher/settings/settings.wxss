.page { min-height: 100vh; background: #F7F8FC; }

/* 设置卡片 */
.section-card {
  background: rgba(255,255,255,0.92);
  border-radius: 24rpx;
  margin: 20rpx 30rpx;
  padding: 28rpx;
  box-shadow: 0 10rpx 30rpx rgba(49,64,90,0.08);
  border: 1rpx solid rgba(255,255,255,0.8);
}
.card-title { font-size: 30rpx; font-weight: bold; display: block; margin-bottom: 20rpx; color: #2F3A4C; }

.field-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #ECEFF5;
}
.field-row:last-child { border-bottom: none; }
.field-label { font-size: 26rpx; color: #7B8496; width: 200rpx; flex-shrink: 0; }
.field-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #2F3A4C;
  padding: 8rpx 0;
}

/* 统一收费列表 */
.fee-list {
  border-top: 2rpx solid #ECEFF5;
}
.fee-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F0F2F6;
}
.fee-item:last-child { border-bottom: none; }

.fee-item-info {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}
.fee-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2F3A4C;
  display: block;
}
.fee-item-meta {
  font-size: 24rpx;
  color: #7B8496;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}
.fee-item-amount {
  font-size: 26rpx;
  font-weight: 600;
  color: #5B7FFF;
  margin-right: 4rpx;
}
.fee-item-unit {
  font-size: 22rpx;
  color: #7B8496;
  margin-right: 8rpx;
}
.fee-item-desc {
  font-size: 22rpx;
  color: #B1B8C7;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 200rpx;
}

.fee-item-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}
.fee-action-btn {
  font-size: 24rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  border: 2rpx solid transparent;
}
.fee-action-btn:active { opacity: 0.7; }
.edit-btn {
  color: #5B7FFF;
  border-color: #D6E0FF;
  background: rgba(91,127,255,0.06);
}
.delete-btn {
  color: #D84A3A;
  border-color: #FFD6D0;
  background: rgba(216,74,58,0.06);
}

/* 添加收费按钮 */
.add-fee-row {
  padding: 20rpx 0 4rpx;
  border-top: 2rpx solid #F0F2F6;
  text-align: center;
}
.add-fee-btn {
  display: inline-block;
  font-size: 26rpx;
  color: #5B7FFF;
  font-weight: 600;
  padding: 10rpx 32rpx;
  border: 2rpx solid #5B7FFF;
  border-radius: 999rpx;
  background: rgba(91,127,255,0.04);
}
.add-fee-btn:active { opacity: 0.7; background: rgba(91,127,255,0.1); }

/* 保存按钮 */
.save-section { padding: 10rpx 30rpx 30rpx; }
.change-hint { font-size: 24rpx; color: #D84A3A; display: block; text-align: center; margin-bottom: 12rpx; }
.save-btn { font-size: 28rpx; }

/* 菜单 */
.menu-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #2F3A4C;
  border-bottom: 2rpx solid #ECEFF5;
}
.menu-row:last-child { border-bottom: none; }
.menu-row:active { opacity: 0.6; }
.menu-arrow { font-size: 32rpx; color: #C7CDD8; }
.logout-text { color: #D84A3A; }

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.4);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}
.modal-content {
  background: #FFF;
  border-radius: 32rpx;
  padding: 40rpx 30rpx;
  width: 600rpx;
  max-height: 80vh;
  overflow-y: auto;
}
.modal-title { font-size: 34rpx; font-weight: bold; color: #2F3A4C; display: block; margin-bottom: 30rpx; text-align: center; }
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: #7B8496; display: block; margin-bottom: 10rpx; }
.form-row { display: flex; gap: 20rpx; }
.form-group.half { flex: 1; }
.modal-actions { display: flex; gap: 20rpx; margin-top: 30rpx; }
.modal-btn { flex: 1; font-size: 28rpx; }
