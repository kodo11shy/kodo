/* 老师工作台 v2 */
.page {
  min-height: 100vh;
  padding-bottom: 50rpx;
  position: relative;
}

/* ===== 背景氛围 ===== */
.bg-accent {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 360rpx;
  background: linear-gradient(180deg, #E8ECFF 0%, #F7F8FC 100%);
  z-index: 0;
  pointer-events: none;
}

/* ===== 顶部区域 ===== */
.dash-header {
  background: #5B7FFF;
  padding: 50rpx 34rpx 34rpx;
  color: #FFFFFF;
  position: relative;
  z-index: 1;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.greeting {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  letter-spacing: 2rpx;
}

.date-text {
  font-size: 24rpx;
  opacity: 0.75;
  margin-top: 10rpx;
  display: block;
}

.logout-btn {
  font-size: 24rpx;
  opacity: 0.85;
  padding: 10rpx 24rpx;
  border: 2rpx solid rgba(255,255,255,0.35);
  border-radius: 999rpx;
  flex-shrink: 0;
  margin-top: 6rpx;
}

/* ===== 头部统计数据 ===== */
.header-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255,255,255,0.15);
  border-radius: 18rpx;
  margin-top: 28rpx;
  padding: 24rpx 16rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  line-height: 1.2;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

.stat-rate {
  color: #8FDCB8;
}

.stat-divider {
  width: 2rpx;
  height: 52rpx;
  background: rgba(255,255,255,0.2);
}

/* ===== 九宫格菜单 ===== */
.grid-menu {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  background: rgba(255,255,255,0.95);
  margin: -24rpx 30rpx 24rpx;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 36rpx rgba(49,64,90,0.10);
  border: 1rpx solid rgba(255,255,255,0.8);
  padding: 8rpx 0;
  position: relative;
  z-index: 2;
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 164rpx;
  padding: 22rpx 10rpx;
  position: relative;
}

.grid-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.grid-icon {
  width: 50rpx;
  height: 50rpx;
}

.grid-icon-emoji {
  font-size: 42rpx;
  line-height: 1;
}

.grid-label {
  font-size: 26rpx;
  color: #2F3A4C;
  font-weight: 500;
}

/* 各图标背景色 */
.icon-camera-bg { background: #EEF2FF; }
.icon-photolib-bg { background: #F0EEFF; }
.icon-checkin-bg { background: #E7F8F3; }
.icon-homework-bg { background: #FFF4ED; }
.icon-growth-bg { background: #FFF0EE; }
.icon-meal-bg { background: #FFF7E8; }
.icon-students-bg { background: #EEF2FF; }
.icon-payment-bg { background: #F0EEFF; }
.icon-notice-bg { background: #E7F8F3; }
.icon-settings-bg { background: #F5F5F7; }
.icon-admin-bg { background: #FFF0EE; }

/* 管理员徽章 */
.admin-badge {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  font-size: 18rpx;
  color: #D84A3A;
  background: #FFF1EF;
  padding: 2rpx 14rpx;
  border-radius: 999rpx;
  line-height: 1.6;
}

/* ===== 今日动态卡片 ===== */
.section-card {
  background: rgba(255,255,255,0.95);
  border-radius: 28rpx;
  margin: 0 30rpx 24rpx;
  padding: 32rpx;
  box-shadow: 0 12rpx 36rpx rgba(49,64,90,0.08);
  border: 1rpx solid rgba(255,255,255,0.8);
  position: relative;
  z-index: 1;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2F3A4C;
}

.section-count {
  font-size: 24rpx;
  color: #7B8496;
}

.dynamic-item {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 2rpx solid #ECEFF5;
}

.dynamic-item:last-child {
  border-bottom: none;
}

.dynamic-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #5B7FFF;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.dynamic-time {
  font-size: 24rpx;
  color: #7B8496;
  width: 130rpx;
  flex-shrink: 0;
}

.dynamic-text {
  font-size: 28rpx;
  color: #2F3A4C;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 动态为空 */
.empty-state-mini {
  padding: 44rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #B1B8C7;
}
