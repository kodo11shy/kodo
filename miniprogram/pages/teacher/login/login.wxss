/* 老师登录页 */
.page {
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  background: #5B7FFF;
}

.login-container {
  width: 85%;
  max-width: 600rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 60rpx 50rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
}

.login-header {
  text-align: center;
  margin-bottom: 50rpx;
}

.login-icon {
  font-size: 80rpx;
  display: block;
}

.login-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #2F3A4C;
  margin-top: 20rpx;
  display: block;
}

.login-desc {
  font-size: 26rpx;
  color: #7B8496;
  margin-top: 10rpx;
  display: block;
}

.login-form {
  margin-top: 20rpx;
}

.input-group {
  position: relative;
  display: flex;
  align-items: center;
  background-color: #F8F8F8;
  border-radius: 12rpx;
  border: 2rpx solid #E8E8E8;
  padding: 0 30rpx;
}

.input-group:focus-within {
  border-color: #5B7FFF;
}

.password-input {
  flex: 1;
  height: 90rpx;
  font-size: 30rpx;
  color: #2F3A4C;
}

.toggle-btn {
  font-size: 36rpx;
  padding: 10rpx;
  color: #7B8496;
}

.error-msg {
  color: #E74C3C;
  font-size: 26rpx;
  margin-top: 16rpx;
  text-align: center;
}

.login-btn {
  margin-top: 40rpx;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 34rpx;
}

.login-btn[disabled] {
  opacity: 0.5;
}

.login-footer {
  text-align: center;
  margin-top: 40rpx;
}

.back-link {
  font-size: 26rpx;
  color: #7B8496;
  text-decoration: underline;
}
