<!-- 系统管理（仅管理员可见） -->
<view class="page">
  <!-- 顶部标签切换 -->
  <view class="admin-tabs">
    <view class="admin-tab {{activeTab === 'teachers' ? 'active' : ''}}" data-tab="teachers" bindtap="switchTab">
      <text>👩‍🏫 老师账号</text>
    </view>
    <view class="admin-tab {{activeTab === 'homework-config' ? 'active' : ''}}" data-tab="homework-config" bindtap="switchTab">
      <text>📋 作业配置</text>
    </view>
    <view class="admin-tab {{activeTab === 'parents' ? 'active' : ''}}" data-tab="parents" bindtap="switchTab">
      <text>👨‍👩‍👧 家长绑定</text>
    </view>
    <view class="admin-tab {{activeTab === 'students' ? 'active' : ''}}" data-tab="students" bindtap="switchTab">
      <text>🎓 学生管理</text>
    </view>
  </view>

  <!-- ====== Tab 1: 老师账号管理 ====== -->
  <view class="tab-content" wx:if="{{activeTab === 'teachers'}}">
    <view class="section-header">
      <text class="section-count">共 {{teachers.length}} 个老师</text>
      <button class="btn-primary btn-sm" bindtap="showAddTeacher">+ 新建老师</button>
    </view>

    <view class="list-card">
      <view class="list-item" wx:for="{{teachers}}" wx:key="id">
        <view class="list-avatar">{{item.avatarChar}}</view>
        <view class="list-info">
          <text class="list-name">{{item.name}}
            <text class="role-tag" wx:if="{{item.role === 'admin'}}">管理员</text>
            <text class="status-tag inactive" wx:if="{{!item.is_active}}">已禁用</text>
          </text>
          <text class="list-desc">{{item.teacherDesc}}</text>
        </view>
        <view class="list-actions">
          <text class="action-btn" bindtap="showEditTeacher" data-id="{{item.id}}">编辑</text>
          <text class="action-btn" wx:if="{{item.role !== 'admin' && item.is_active}}" bindtap="confirmDisableTeacher" data-id="{{item.id}}" data-name="{{item.name}}">禁用</text>
          <text class="action-btn" wx:if="{{!item.is_active}}" bindtap="enableTeacher" data-id="{{item.id}}">启用</text>
          <text class="action-btn reset" bindtap="showResetPwd" data-id="{{item.id}}" data-name="{{item.name}}">重置密码</text>
        </view>
      </view>
      <view class="empty-state" wx:if="{{teachers.length === 0}}">
        <text class="empty-text">暂无老师账号</text>
      </view>
    </view>
  </view>

  <!-- ====== Tab 2: 作业配置 ====== -->
  <view class="tab-content" wx:if="{{activeTab === 'homework-config'}}">
    <!-- 科目配置 -->
    <view class="section-header">
      <text class="section-count">📖 科目管理</text>
    </view>
    <view class="config-card">
      <text class="config-note">作业科目固定为语文和数学，避免老师串科或统计口径混乱。</text>
      <view class="config-tags">
        <view class="config-tag" wx:for="{{homeworkSubjects}}" wx:key="*this">
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 作业类型配置 -->
    <view class="section-header" style="margin-top: 20rpx;">
      <text class="section-count">📂 作业类型管理</text>
    </view>
    <view class="config-card">
      <view class="config-tags">
        <view class="config-tag" wx:for="{{homeworkTypes}}" wx:key="*this">
          <text>{{item}}</text>
          <text class="tag-del" bindtap="removeHomeworkType" data-type="{{item}}">✕</text>
        </view>
      </view>
      <view class="config-add-row">
        <input class="config-input" placeholder="输入新作业类型" value="{{newHomeworkType}}" bindinput="onNewHomeworkType" />
        <button class="btn-primary btn-sm" bindtap="addHomeworkType" disabled="{{!newHomeworkType}}">添加</button>
      </view>
    </view>
  </view>

  <!-- ====== Tab 3: 家长绑定管理 ====== -->
  <view class="tab-content" wx:if="{{activeTab === 'parents'}}">
    <view class="section-header">
      <text class="section-count">共 {{parentBindings.length}} 个绑定</text>
    </view>

    <view class="list-card">
      <view class="list-item" wx:for="{{parentBindings}}" wx:key="id">
        <view class="list-avatar">{{item.avatarChar}}</view>
        <view class="list-info">
          <text class="list-name">{{item.displayName}}
            <text class="status-tag inactive" wx:if="{{!item.is_active}}">已解绑</text>
          </text>
          <text class="list-desc">孩子：{{item.student_name}} · {{item.relation ? item.relation : '—'}} · {{item.phone ? item.phone : '无电话'}}</text>
        </view>
        <view class="list-actions">
          <text class="action-btn danger" wx:if="{{item.is_active}}" bindtap="confirmUnbind" data-id="{{item.id}}" data-name="{{item.parent_name}}" data-student="{{item.student_name}}">解绑</text>
        </view>
      </view>
      <view class="empty-state" wx:if="{{parentBindings.length === 0}}">
        <text class="empty-text">暂无家长绑定</text>
      </view>
    </view>
  </view>

  <!-- ====== Tab 4: 学生管理（退班） ====== -->
  <view class="tab-content" wx:if="{{activeTab === 'students'}}">
    <view class="section-header">
      <text class="section-count">共 {{students.length}} 个学生</text>
    </view>

    <view class="list-card">
      <view class="list-item" wx:for="{{students}}" wx:key="id">
        <view class="list-avatar">{{item.avatarChar}}</view>
        <view class="list-info">
          <text class="list-name">{{item.name}}
            <text class="status-tag inactive" wx:if="{{item.status === '已退班'}}">已退班</text>
            <text class="status-tag active" wx:if="{{item.status === '在读'}}">在读</text>
          </text>
          <text class="list-desc">{{item.grade ? item.grade : '—'}} · {{item.school_name ? item.school_name : ''}}</text>
        </view>
        <view class="list-actions">
          <text class="action-btn danger" wx:if="{{item.status === '在读'}}" bindtap="confirmWithdraw" data-id="{{item.id}}" data-name="{{item.name}}">退班</text>
          <text class="action-btn" wx:if="{{item.status === '已退班'}}" bindtap="restoreStudent" data-id="{{item.id}}" data-name="{{item.name}}">恢复</text>
        </view>
      </view>
      <view class="empty-state" wx:if="{{students.length === 0}}">
        <text class="empty-text">暂无学生</text>
      </view>
    </view>
  </view>

  <!-- 新建/编辑老师弹窗 -->
  <view class="modal-overlay" wx:if="{{showForm}}" bindtap="closeForm">
    <view class="form-dialog" catchtap="nop">
      <text class="form-title">{{formEditId ? '编辑老师' : '新建老师'}}</text>
      <view class="form-group">
        <text class="form-label">姓名</text>
        <input class="form-input" placeholder="输入老师姓名" value="{{formName}}" bindinput="onFormName" />
      </view>
      <view class="form-group">
        <text class="form-label">手机号（选填）</text>
        <input class="form-input" placeholder="输入手机号" value="{{formPhone}}" bindinput="onFormPhone" type="number" maxlength="11" />
      </view>
      <view class="form-group" wx:if="{{!formEditId}}">
        <text class="form-label">登录密码</text>
        <input class="form-input" placeholder="输入密码（至少6位）" value="{{formPassword}}" bindinput="onFormPassword" type="text" />
      </view>
      <view class="form-group">
        <text class="form-label">角色</text>
        <picker class="form-picker" range="{{roleOptions}}" value="{{formRoleIndex}}" bindchange="onFormRole">
          <text>{{roleOptions[formRoleIndex]}}</text>
        </picker>
      </view>
      <view class="form-group">
        <text class="form-label">学科</text>
        <picker class="form-picker" range="{{formSubjectOptions}}" value="{{formSubjectIndex}}" bindchange="onFormSubject">
          <text>{{formSubjectOptions[formSubjectIndex]}}</text>
        </picker>
      </view>
      <view class="form-actions">
        <button class="btn-secondary" bindtap="closeForm">取消</button>
        <button class="btn-primary" bindtap="saveTeacher" loading="{{formLoading}}" disabled="{{!formCanSave}}">{{formSaveText}}</button>
      </view>
    </view>
  </view>

  <!-- 重置密码弹窗 -->
  <view class="modal-overlay" wx:if="{{showResetPwd}}" bindtap="closeResetPwd">
    <view class="form-dialog" catchtap="nop">
      <text class="form-title">重置密码</text>
      <text class="form-hint">确认后将重置 {{resetPwdName}} 的登录密码，并自动复制新密码。</text>
      <view class="temp-pwd-box">
        <text class="temp-pwd">{{resetPwdNewPwd ? resetPwdNewPwd : '待生成'}}</text>
      </view>
      <view class="form-actions">
        <button class="btn-secondary" bindtap="closeResetPwd">取消</button>
        <button class="btn-primary" bindtap="doResetPwd" loading="{{resetPwdLoading}}" disabled="{{resetPwdLoading}}">{{resetPwdLoading ? '重置中...' : '确认重置'}}</button>
      </view>
    </view>
  </view>
</view>
