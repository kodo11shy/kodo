/* 作业详情页 */
.page {
  min-height: 100vh;
  background: #F7F8FC;
  padding-bottom: 40rpx;
}

/* 头部卡片 */
.header-card {
  background: #5B7FFF;
  padding: 40rpx 30rpx;
  color: #FFFFFF;
  position: relative;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.student-name {
  font-size: 36rpx;
  font-weight: bold;
}

.status-tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.tag-pending {
  background-color: #FFF3E0;
  color: #F39C12;
}

.tag-graded {
  background-color: #E8F4FD;
  color: #5B7FFF;
}

.tag-done {
  background-color: #E8F8E8;
  color: #27AE60;
}

.header-meta {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  opacity: 0.85;
  margin-top: 12rpx;
}

.header-score {
  text-align: center;
  margin-top: 20rpx;
}

/* 操作人审计行 */
.audit-row {
  margin-top: 16rpx;
  border-top: 2rpx solid rgba(255,255,255,0.2);
  padding-top: 14rpx;
}
.audit-line {
  display: block;
  font-size: 22rpx;
  opacity: 0.85;
  line-height: 1.8;
}
.audit-time {
  opacity: 0.7;
  font-size: 20rpx;
}

.score-num {
  font-size: 72rpx;
  font-weight: bold;
}

.score-label {
  font-size: 28rpx;
  opacity: 0.8;
}

/* 步骤区块 */
.step-section {
  background-color: #FFFFFF;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.step-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.step-num {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.step-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #2F3A4C;
  flex: 1;
}

.step-status {
  font-size: 24rpx;
}

.done-status {
  color: #27AE60;
}

.pending {
  color: #F39C12;
}

/* 照片滚动 */
.photo-scroll {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.photo-scroll .photo-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #F0F0F0;
}

/* 批改表单 */
.grade-form {
  margin-top: 20rpx;
  border-top: 2rpx solid #ECEFF5;
  padding-top: 20rpx;
}

.form-row {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #7B8496;
  display: block;
  margin-bottom: 12rpx;
}

/* 评分选择 */
.score-picker {
  display: flex;
  gap: 8rpx;
}

.score-star {
  font-size: 40rpx;
  opacity: 0.3;
  transition: opacity 0.2s;
}

.score-star.active {
  opacity: 1;
}

/* 错题数 */
.error-input {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.num-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #F0F0F0;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
  color: #7B8496;
}

.num-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #2F3A4C;
  min-width: 60rpx;
  text-align: center;
}

/* 照片网格 */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.photo-grid .photo-cell {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.photo-grid .photo-thumb {
  width: 100%;
  height: 100%;
  background-color: #F0F0F0;
}

.photo-del {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background-color: rgba(0,0,0,0.5);
  color: #FFFFFF;
  font-size: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.photo-add {
  background-color: #F8F8F8;
  border: 2rpx dashed #CCCCCC;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 48rpx;
  color: #CCCCCC;
}

/* 文本域 */
.textarea-field {
  width: 100%;
  height: 120rpx;
  background-color: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  border: 2rpx solid #E8E8E8;
}

.grade-btn {
  margin-top: 10rpx;
}

/* 评语文本 */
.remark-text {
  font-size: 26rpx;
  color: #7B8496;
  background-color: #F9F9F9;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 16rpx;
  white-space: pre-wrap;
}

/* 底部 */
.bottom-bar {
  padding: 20rpx 30rpx;
}
