/* 作业列表页 */
.page { min-height: 100vh; background: #F7F8FC; padding-bottom: 120rpx; }

/* ====== 总览卡片 ====== */
.overview-card {
  background: #FFF;
  margin: 20rpx 24rpx;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(49,64,90,0.06);
}
.overview-title { font-size: 30rpx; font-weight: bold; color: #2F3A4C; margin-bottom: 20rpx; }

.overview-attendance { display: flex; align-items: center; margin-bottom: 8rpx; }
.ov-att-icon { font-size: 28rpx; margin-right: 8rpx; }
.ov-att-text { font-size: 26rpx; color: #7B8496; }
.ov-att-num { font-size: 30rpx; font-weight: bold; color: #5B7FFF; }
.ov-att-total { font-size: 26rpx; color: #B1B8C7; }
.ov-att-names { font-size: 24rpx; color: #B1B8C7; margin-bottom: 20rpx; padding-left: 4rpx; line-height: 1.6; }
.ov-att-empty { font-size: 24rpx; color: #B1B8C7; margin-bottom: 20rpx; }

/* 科目网格 */
.subject-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.subject-cell {
  flex: 1;
  min-width: calc(50% - 6rpx);
  background: #F7F8FC;
  border-radius: 16rpx;
  padding: 20rpx;
}
.subj-icon { font-size: 28rpx; margin-right: 6rpx; }
.subj-name { font-size: 26rpx; color: #2F3A4C; font-weight: bold; }
.subj-total { font-size: 22rpx; color: #B1B8C7; display: block; margin: 6rpx 0 10rpx; }

/* 进度条 */
.subj-bar { height: 8rpx; border-radius: 999rpx; background: #F0F2F5; display: flex; overflow: hidden; margin-bottom: 10rpx; }
.subj-bar-inner { height: 100%; }
.bar-pending { background: #FF8C42; }
.bar-graded { background: #5B7FFF; }
.bar-done { background: #4CAF50; }

/* 图例 */
.subj-legend { font-size: 20rpx; color: #B1B8C7; display: flex; align-items: center; gap: 12rpx; flex-wrap: wrap; }
.legend-dot { display: inline-block; width: 10rpx; height: 10rpx; border-radius: 50%; margin-right: 4rpx; }
.dot-pending { background: #FF8C42; }
.dot-graded { background: #5B7FFF; }
.dot-done { background: #4CAF50; }

.ov-empty { font-size: 24rpx; color: #B1B8C7; text-align: center; padding: 20rpx 0; }

/* ====== 状态说明 ====== */
.status-hint-bar { display: flex; align-items: center; padding: 16rpx 24rpx; background: #FFF8F0; gap: 8rpx; }
.hint-icon { font-size: 24rpx; }
.hint-text { font-size: 24rpx; color: #7B8496; }
.status-hint-detail { background: #FFFDF5; padding: 12rpx 24rpx 20rpx; border-bottom: 2rpx solid #F5F6F8; }
.hint-line { display: block; font-size: 24rpx; color: #7B8496; line-height: 1.8; }
.hint-emoji { margin-right: 6rpx; }

/* ====== 状态 tabs ====== */
.tabs { display: flex; background: #FFF; padding: 16rpx 24rpx; gap: 12rpx; position: sticky; top: 0; z-index: 10; }
.tab { flex: 1; padding: 14rpx 0; text-align: center; font-size: 26rpx; color: #7B8496; border-radius: 999rpx; background: #F0F2F5; }
.tab.active { background: #EEF1FF; color: #5B7FFF; font-weight: 600; }

/* ====== 新建按钮 ====== */
.create-bar { position: fixed; bottom: 0; left: 0; right: 0; padding: 20rpx 30rpx; background: #FFF; box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06); z-index: 20; }
.create-btn { width: 100%; height: 88rpx; border-radius: 999rpx; background: #5B7FFF; color: #FFF; font-size: 30rpx; font-weight: 600; display: flex; align-items: center; justify-content: center; gap: 8rpx; box-shadow: 0 4rpx 16rpx rgba(91,127,255,0.3); }
.create-btn:active { opacity: 0.85; }

/* ====== 列表 ====== */
.list { padding: 16rpx 24rpx; }
.card { background: #FFF; border-radius: 20rpx; padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 4rpx 16rpx rgba(49,64,90,0.06); }
.card:active { opacity: 0.7; }
.card-top { display: flex; justify-content: space-between; align-items: center; }
.card-student { font-size: 30rpx; font-weight: bold; color: #2F3A4C; }
.card-subject { font-size: 26rpx; color: #7B8496; margin-left: 12rpx; }
.card-status { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 999rpx; flex-shrink: 0; }
.tag-pending { background: #FFF3E8; color: #FF8C42; }
.tag-graded { background: #E3F2FD; color: #2196F3; }
.tag-done { background: #E8F5E9; color: #4CAF50; }
.card-body { margin-top: 14rpx; display: flex; justify-content: space-between; align-items: center; }
.card-meta { font-size: 24rpx; color: #B1B8C7; }
.card-score { font-size: 26rpx; color: #5B7FFF; font-weight: 600; }
.card-operator { margin-top: 8rpx; }
.op-text { font-size: 22rpx; color: #B1B8C7; }
.card-photos { display: flex; gap: 6rpx; margin-top: 12rpx; }
.card-photo-thumb { width: 80rpx; height: 80rpx; border-radius: 8rpx; background: #F0F0F0; }
.card-empty-text { font-size: 24rpx; color: #B1B8C7; }

/* ====== 加载 & 空状态 ====== */
.loading-container { display: flex; justify-content: center; align-items: center; height: 40vh; color: #B1B8C7; font-size: 28rpx; }
.empty-state { text-align: center; padding: 120rpx 30rpx; color: #B1B8C7; font-size: 28rpx; }
