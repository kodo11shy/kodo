/* 新建作业页 */
.page {
  min-height: 100vh;
  background: #F7F8FC;
  padding-bottom: 120rpx;
}

.form-section {
  padding: 20rpx 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #2F3A4C;
  font-weight: bold;
  margin-bottom: 16rpx;
  display: block;
}

.picker-box {
  background-color: #F8F8F8;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  font-size: 30rpx;
  color: #2F3A4C;
  border: 2rpx solid #E8E8E8;
}

.picker-empty {
  color: #B1B8C7;
}

/* 科目锁定 */
.subject-locked {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}
.locked-tag {
  background: #EEF1FF;
  color: #5B7FFF;
  font-size: 28rpx;
  padding: 12rpx 28rpx;
  border-radius: 12rpx;
  font-weight: 600;
}
.locked-hint {
  font-size: 22rpx;
  color: #B1B8C7;
}

/* 学生计数 */
.student-count {
  font-size: 22rpx;
  color: #B1B8C7;
  font-weight: normal;
}

/* 科目选择 */
.subject-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.subject-tag {
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  background-color: #F5F5F5;
  font-size: 28rpx;
  color: #7B8496;
}

.subject-tag.active {
  background-color: #E8F4FD;
  color: #5B7FFF;
  border: 2rpx solid #5B7FFF;
}

/* 照片网格 */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-cell {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.photo-thumb {
  width: 100%;
  height: 100%;
  background-color: #F0F0F0;
}

.photo-del {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: rgba(0,0,0,0.5);
  color: #FFFFFF;
  font-size: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.photo-add {
  background-color: #F8F8F8;
  border: 2rpx dashed #CCCCCC;
  display: flex;
  justify-content: center;
  align-items: center;
}

.add-icon {
  font-size: 60rpx;
  color: #CCCCCC;
}

/* 备注 */
.textarea-field {
  width: 100%;
  height: 160rpx;
  background-color: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid #E8E8E8;
}

/* 提交 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
}
