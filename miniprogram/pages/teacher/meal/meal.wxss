.page { min-height: 100vh; background: #F7F8FC; padding-bottom: 40rpx; }

/* 状态卡 */
.overview-card {
  background: #5B7FFF;
  margin: 30rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  color: #FFF;
}
.overview-head { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24rpx; }
.overview-title { font-size: 34rpx; font-weight: bold; display: block; }
.overview-subtitle { font-size: 24rpx; opacity: 0.85; margin-top: 6rpx; display: block; }
.mini-action {
  background: rgba(255,255,255,0.25);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}
.metric-grid { display: flex; gap: 16rpx; }
.metric-item { flex: 1; text-align: center; }
.metric-value { font-size: 40rpx; font-weight: bold; display: block; }
.metric-label { font-size: 22rpx; opacity: 0.85; margin-top: 4rpx; display: block; }

/* 待处理卡 */
.todo-card {
  background: #FFF;
  margin: 0 30rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.todo-head { display: flex; justify-content: space-between; margin-bottom: 16rpx; }
.todo-title { font-size: 28rpx; font-weight: bold; }
.todo-count { font-size: 24rpx; color: #FF6B35; }
.todo-row {
  display: flex; justify-content: space-between;
  padding: 16rpx 0;
  border-top: 2rpx solid #ECEFF5;
  font-size: 26rpx;
}
.todo-row:first-of-type { border-top: none; }
.todo-num { color: #5B7FFF; }

/* 筛选 */
.filter-scroll { white-space: nowrap; padding: 0 30rpx 20rpx; }
.filter-row { display: inline-flex; gap: 16rpx; }
.filter-chip {
  display: inline-flex; align-items: center; gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  background: #FFF;
  border: 2rpx solid #E8E8E8;
  color: #666;
}
.filter-chip.active {
  background: #5B7FFF;
  border-color: #5B7FFF;
  color: #FFF;
}
.filter-count {
  background: rgba(0,0,0,0.06);
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}
.filter-chip.active .filter-count {
  background: rgba(255,255,255,0.25);
}

/* 餐食卡片 */
.meal-list { padding: 0 30rpx 30rpx; }
.meal-card {
  background: #FFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.meal-header-row { display: flex; justify-content: space-between; align-items: center; }
.meal-header-left { display: flex; align-items: center; gap: 12rpx; }
.meal-date { font-size: 28rpx; font-weight: bold; }
.meal-type { font-size: 22rpx !important; }
.meal-menu { font-size: 30rpx; margin-top: 12rpx; display: block; color: #333; }
.meal-remark { font-size: 26rpx; color: #666; margin-top: 8rpx; display: block; }
.meal-photos { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 12rpx; }
.meal-thumb { width: 160rpx; height: 160rpx; border-radius: 12rpx; background: #F5F5F5; }
.card-arrow { color: #CCC; font-size: 28rpx; padding: 8rpx; }

/* 展开详情 */
.meal-detail { margin-top: 16rpx; padding-top: 16rpx; border-top: 2rpx solid #F0F0F0; }
.detail-section { margin-bottom: 12rpx; }
.detail-label { font-size: 24rpx; font-weight: bold; color: #999; display: block; margin-bottom: 8rpx; }
.detail-section text { font-size: 24rpx; color: #666; display: block; line-height: 1.6; }
.photo-group-badges { display: flex; flex-wrap: wrap; gap: 8rpx; }
.group-badge {
  font-size: 22rpx;
  color: #666;
  background: #F5F5F5;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 弹窗 */
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: #666; margin-bottom: 8rpx; display: block; }
.textarea-field { height: 120rpx; padding: 20rpx; }
.picker-field {
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  border: 2rpx solid #E8E8E8;
}

/* 照片分组 */
.photo-groups { }
.photo-group { margin-bottom: 20rpx; padding: 16rpx; background: #F8F8F8; border-radius: 12rpx; }
.photo-group-header { display: flex; justify-content: space-between; align-items: center; }
.photo-group-label { font-size: 24rpx; color: #666; }
.photo-add-btn { font-size: 24rpx; color: #5B7FFF; padding: 8rpx; }
.photo-thumbs { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 10rpx; }
.thumb-wrap { position: relative; }
.thumb { width: 120rpx; height: 120rpx; border-radius: 8rpx; background: #DDD; }
.thumb-remove {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: rgba(0,0,0,0.5);
  color: #FFF;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 32rpx;
  font-size: 20rpx;
}
