.page { min-height: 100vh; background: #F7F8FC; padding-bottom: 40rpx; }

/* 状态卡 */
.overview-card {
  background: #5B7FFF;
  margin: 30rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  color: #FFF;
}
.overview-head { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24rpx; }
.overview-title { font-size: 34rpx; font-weight: bold; display: block; }
.overview-subtitle { font-size: 24rpx; opacity: 0.85; margin-top: 6rpx; display: block; }
.mini-action {
  background: rgba(255,255,255,0.25);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}
.metric-grid { display: flex; gap: 16rpx; }
.metric-item { flex: 1; text-align: center; }
.metric-value { font-size: 40rpx; font-weight: bold; display: block; }
.metric-label { font-size: 22rpx; opacity: 0.85; margin-top: 4rpx; display: block; }

/* 待处理卡 */
.todo-card {
  background: #FFF;
  margin: 0 30rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.todo-head { display: flex; justify-content: space-between; margin-bottom: 16rpx; }
.todo-title { font-size: 28rpx; font-weight: bold; }
.todo-count { font-size: 24rpx; color: #FF6B35; }
.todo-row {
  display: flex; justify-content: space-between;
  padding: 16rpx 0;
  border-top: 2rpx solid #ECEFF5;
  font-size: 26rpx;
}
.todo-row:first-of-type { border-top: none; }
.todo-num { color: #5B7FFF; }

/* 筛选 */
.filter-scroll { white-space: nowrap; padding: 0 30rpx 20rpx; }
.filter-row { display: inline-flex; gap: 16rpx; }
.filter-chip {
  display: inline-flex; align-items: center; gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  background: #FFF;
  border: 2rpx solid #E8E8E8;
  color: #666;
}
.filter-chip.active {
  background: #5B7FFF;
  border-color: #5B7FFF;
  color: #FFF;
}
.filter-count {
  background: rgba(0,0,0,0.06);
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}
.filter-chip.active .filter-count {
  background: rgba(255,255,255,0.25);
}

/* 通知卡片 */
.notice-list { padding: 0 30rpx 30rpx; }
.notice-card {
  background: #FFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.notice-header { display: flex; align-items: center; flex-wrap: wrap; gap: 8rpx; }
.notice-title { font-size: 30rpx; font-weight: bold; flex: 1; }
.notice-type { font-size: 22rpx !important; }
.pin-tag { font-size: 22rpx !important; }
.notice-content { font-size: 28rpx; color: #555; margin-top: 12rpx; display: block; line-height: 1.6; }
.notice-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 16rpx; padding-top: 12rpx; border-top: 2rpx solid #ECEFF5; }
.notice-date { font-size: 22rpx; color: #BBB; }
.notice-actions { display: flex; gap: 20rpx; }
.action-edit { font-size: 24rpx; color: #5B7FFF; }
.action-delete { font-size: 24rpx; color: #E74C3C; }

/* 状态标签 */
.state-tag { font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 20rpx; }
.tag-ok { background: #E8F5E9; color: #2E7D32; }
.tag-warn { background: #FFF3E0; color: #E65100; }
.tag-danger { background: #FFEBEE; color: #C62828; }
.tag-muted { background: #F5F5F5; color: #999; }

/* 弹窗 */
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: #666; margin-bottom: 8rpx; display: block; }
.textarea-field { height: 160rpx; padding: 20rpx; }
.form-row { display: flex; gap: 20rpx; }
.half { flex: 1; }
.picker-field {
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  border: 2rpx solid #E8E8E8;
}
.toggle-row { display: flex; align-items: center; gap: 16rpx; }
