.page { min-height: 100vh; background: #F7F8FC; padding-bottom: 40rpx; }

/* 状态卡 */
.overview-card {
  background: #5B7FFF;
  margin: 30rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  color: #FFF;
}
.overview-head { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24rpx; }
.overview-title { font-size: 34rpx; font-weight: bold; display: block; }
.overview-subtitle { font-size: 24rpx; opacity: 0.85; margin-top: 6rpx; display: block; }
.mini-action {
  background: rgba(255,255,255,0.25);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}
.metric-grid { display: flex; gap: 16rpx; }
.metric-item { flex: 1; text-align: center; }
.metric-value { font-size: 40rpx; font-weight: bold; display: block; }
.metric-label { font-size: 22rpx; opacity: 0.85; margin-top: 4rpx; display: block; }

/* 待处理卡 */
.todo-card {
  background: #FFF;
  margin: 0 30rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.todo-head { display: flex; justify-content: space-between; margin-bottom: 16rpx; }
.todo-title { font-size: 28rpx; font-weight: bold; }
.todo-row {
  display: flex; justify-content: space-between;
  padding: 16rpx 0;
  border-top: 2rpx solid #ECEFF5;
  font-size: 26rpx;
}
.todo-row:first-of-type { border-top: none; }
.todo-num { color: #5B7FFF; }

/* 模式切换 */
.mode-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx 20rpx;
}
.mode-tabs {
  display: flex;
  background: #FFF;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx solid #E8E8E8;
}
.mode-tab {
  display: flex;
  align-items: center;
  padding: 14rpx 40rpx;
  font-size: 26rpx;
  color: #666;
}
.mode-tab.active {
  background: #5B7FFF;
  color: #FFF;
}
.mode-icon { margin-right: 8rpx; }

/* 分区 */
.section { padding: 0 30rpx; margin-bottom: 20rpx; }
.section-title { font-size: 28rpx; font-weight: bold; color: #333; margin-bottom: 16rpx; display: block; }

/* 学生卡片 */
.student-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.student-card {
  width: calc(50% - 8rpx);
  display: flex;
  align-items: center;
  background: #FFF;
  border-radius: 14rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  border: 2rpx solid transparent;
}
.student-card.checked-in { border-color: #E8F8E8; }
.student-card.not-checked { border-color: #F5F5F5; }
.student-avatar {
  width: 64rpx; height: 64rpx;
  border-radius: 50%;
  background: #5B7FFF;
  color: #FFF;
  display: flex; justify-content: center; align-items: center;
  font-size: 28rpx; font-weight: bold;
  margin-right: 16rpx; flex-shrink: 0;
}
.student-card.not-checked .student-avatar { background: #E0E0E0; }
.student-info { flex: 1; min-width: 0; }
.student-name { font-size: 28rpx; font-weight: bold; color: #333; display: block; }
.student-time, .student-desc { font-size: 22rpx; color: #999; margin-top: 4rpx; display: block; }
.student-time { color: #27AE60; }
.action-btn {
  font-size: 24rpx; color: #5B7FFF;
  padding: 8rpx 16rpx;
  border: 2rpx solid #5B7FFF;
  border-radius: 8rpx;
  flex-shrink: 0;
}
.status-badge {
  font-size: 20rpx; color: #F39C12;
  background: #FFF3E0;
  padding: 6rpx 12rpx; border-radius: 6rpx;
  flex-shrink: 0;
}

/* 空状态 */
.empty-state { text-align: center; padding: 80rpx 30rpx; }
.empty-title { font-size: 28rpx; color: #999; display: block; }
.empty-desc { font-size: 24rpx; color: #CCC; margin-top: 8rpx; display: block; }

/* 弹窗 */
.modal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex; justify-content: center; align-items: center;
  z-index: 100;
}
.modal-content {
  width: 80%; max-width: 560rpx;
  background: #FFF;
  border-radius: 20rpx;
  padding: 50rpx 40rpx;
  display: flex; flex-direction: column; align-items: center;
}
.modal-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.modal-title { font-size: 36rpx; font-weight: bold; color: #333; }
.modal-desc { font-size: 28rpx; color: #666; margin-top: 12rpx; }
.modal-actions { display: flex; gap: 20rpx; width: 100%; margin-top: 20rpx; }
.modal-actions .modal-btn { flex: 1; }
.makeup-form { width: 100%; margin-top: 30rpx; }
.form-label { font-size: 26rpx; color: #666; display: block; margin-bottom: 10rpx; margin-top: 20rpx; }
.picker-value {
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx 30rpx;
  font-size: 30rpx; color: #333;
  border: 2rpx solid #E8E8E8;
}
.input-field {
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  border: 2rpx solid #E8E8E8;
  width: 100%;
  box-sizing: border-box;
}
