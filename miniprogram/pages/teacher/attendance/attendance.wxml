<view class="page">

  <!-- 顶部状态卡 -->
  <view class="overview-card">
    <view class="overview-head">
      <view>
        <text class="overview-title">{{dateStr}} 签到</text>
        <text class="overview-subtitle">今日签到率 {{checkinRate}}</text>
      </view>
      <view class="mini-action" bindtap="goStudentList">学生管理</view>
    </view>
    <view class="metric-grid">
      <view class="metric-item">
        <text class="metric-value">{{totalCount}}</text>
        <text class="metric-label">总人数</text>
      </view>
      <view class="metric-item">
        <text class="metric-value">{{checkedInCount}}</text>
        <text class="metric-label">已签到</text>
      </view>
      <view class="metric-item">
        <text class="metric-value">{{checkedOutCount}}</text>
        <text class="metric-label">已签退</text>
      </view>
      <view class="metric-item">
        <text class="metric-value">{{notCheckedInCount}}</text>
        <text class="metric-label">未签到</text>
      </view>
    </view>
  </view>

  <!-- 待处理队列 -->
  <view class="todo-card" wx:if="{{pendingAction.length > 0}}">
    <view class="todo-head">
      <text class="todo-title">待处理</text>
    </view>
    <view class="todo-row" wx:for="{{pendingAction}}" wx:key="action">
      <text>⏳ {{item.text}}</text>
      <text class="todo-num">{{item.count}} 人</text>
    </view>
  </view>

  <!-- 模式切换 -->
  <view class="mode-bar">
    <view class="mode-tabs">
      <view class="mode-tab {{checkinTabClass}}" bindtap="switchMode" data-mode="checkin">
        <text class="mode-icon">🔵</text>
        <text>签到</text>
      </view>
      <view class="mode-tab {{checkoutTabClass}}" bindtap="switchMode" data-mode="checkout">
        <text class="mode-icon">🟠</text>
        <text>签退</text>
      </view>
    </view>
  </view>

  <!-- 已签到列表 -->
  <view class="section" wx:if="{{checkedInList.length > 0}}">
    <text class="section-title">✅ 已签到（{{checkedInList.length}}）</text>
    <view class="student-list">
      <view class="student-card checked-in" wx:for="{{checkedInList}}" wx:key="student_id" bindtap="onStudentTap" data-student="{{item}}" data-checked="{{true}}" bindlongpress="onMakeupTap">
        <view class="student-avatar">{{item.initial}}</view>
        <view class="student-info">
          <text class="student-name">{{item.name}}</text>
          <text class="student-time" wx:if="{{isCheckinMode}}">签到 {{item.checkin_time}}</text>
          <text class="student-time" wx:if="{{isCheckoutMode}}">{{item.checkoutText}}</text>
        </view>
        <text class="status-badge" wx:if="{{item.is_makeup}}">补签</text>
      </view>
    </view>
  </view>

  <!-- 未签到列表 -->
  <view class="section" wx:if="{{notCheckedInList.length > 0}}">
    <text class="section-title">⏳ {{uncheckedSectionTitle}}（{{notCheckedInList.length}}）</text>
    <view class="student-list">
      <view class="student-card not-checked" wx:for="{{notCheckedInList}}" wx:key="student_id" bindtap="onStudentTap" data-student="{{item}}" data-checked="{{false}}" bindlongpress="onMakeupTap">
        <view class="student-avatar">{{item.initial}}</view>
        <view class="student-info">
          <text class="student-name">{{item.name}}</text>
          <text class="student-desc">{{uncheckedDescText}}</text>
        </view>
        <text class="action-btn">{{uncheckedActionText}}</text>
      </view>
    </view>
  </view>

  <!-- 所有都已签到 -->
  <view class="empty-state" wx:if="{{checkedInList.length === 0 && notCheckedInList.length === 0}}">
    <text class="empty-title">暂无签到数据</text>
    <text class="empty-desc">今天还没有签到记录</text>
  </view>

  <!-- 补签弹窗 -->
  <view class="modal-overlay" wx:if="{{showMakeup}}" bindtap="cancelMakeup">
    <view class="modal-content" catchtap="nop">
      <text class="modal-icon">📝</text>
      <text class="modal-title">补签</text>
      <text class="modal-desc">学生：{{makeupStudent.name}}</text>
      <view class="makeup-form">
        <text class="form-label">时间</text>
        <picker mode="time" value="{{makeupTime}}" bindchange="onMakeupTimeChange">
          <view class="picker-value">{{makeupTime}}</view>
        </picker>
        <text class="form-label">原因</text>
        <input class="input-field" placeholder="请输入补签原因" value="{{makeupReason}}" bindinput="onMakeupReasonInput" />
      </view>
      <view class="modal-actions">
        <button class="btn-secondary modal-btn" bindtap="cancelMakeup">取消</button>
        <button class="btn-primary modal-btn" bindtap="confirmMakeup">确认补签</button>
      </view>
    </view>
  </view>
</view>
