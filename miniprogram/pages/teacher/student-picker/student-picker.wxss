/* 学生选择页 */
.page {
  min-height: 100vh;
  background: #F7F8FC;
  padding-bottom: 120rpx;
}

/* 顶部 */
.header-bar {
  padding: 30rpx 30rpx 10rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #2F3A4C;
  display: block;
}

.header-desc {
  font-size: 26rpx;
  color: #7B8496;
  margin-top: 8rpx;
  display: block;
}

/* 模式选择 */
.mode-bar {
  display: flex;
  padding: 10rpx 30rpx;
  gap: 20rpx;
}

.mode-tab {
  padding: 12rpx 40rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  background-color: #F5F5F5;
  color: #7B8496;
}

.mode-tab.active {
  background-color: #5B7FFF;
  color: #FFFFFF;
}

/* 照片预览 */
.photo-preview {
  padding: 0 30rpx;
}

.preview-img {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
  background-color: #F0F0F0;
}

/* 学生网格 */
.student-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 20rpx;
  gap: 12rpx;
}

.student-item {
  width: calc(20% - 10rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.student-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: #E8F4FD;
  color: #5B7FFF;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 36rpx;
  font-weight: bold;
  position: relative;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.student-avatar.selected {
  background-color: #5B7FFF;
  color: #FFFFFF;
  border-color: #2D6DB5;
}

.check-mark {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: #27AE60;
  color: #FFFFFF;
  font-size: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.student-name {
  font-size: 24rpx;
  color: #2F3A4C;
  margin-top: 8rpx;
  text-align: center;
}

.student-name.selected-text {
  color: #5B7FFF;
  font-weight: bold;
}

.student-grade {
  font-size: 20rpx;
  color: #7B8496;
  text-align: center;
}

/* 分类 */
.type-section {
  padding: 20rpx 30rpx;
}

.section-label {
  font-size: 28rpx;
  color: #2F3A4C;
  display: block;
  margin-bottom: 16rpx;
}

.type-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-tag {
  padding: 16rpx 30rpx;
  border-radius: 12rpx;
  background-color: #F5F5F5;
  font-size: 26rpx;
  color: #7B8496;
}

.type-tag.active {
  background-color: #E8F4FD;
  color: #5B7FFF;
  border: 2rpx solid #5B7FFF;
}

/* 备注 */
.remark-section {
  padding: 0 30rpx;
}

.remark-input {
  width: 100%;
  height: 140rpx;
  background-color: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  border: 2rpx solid #E8E8E8;
}

/* 底部确认 */
.confirm-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
}
