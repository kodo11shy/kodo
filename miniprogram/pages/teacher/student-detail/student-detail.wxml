<view class="page">
  <!-- 加载 -->
  <view class="loading-container" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <block wx:else>
    <block wx:if="{{student}}">
      <!-- 头部信息 -->
      <view class="profile-header">
        <view class="profile-avatar">{{student.initial}}</view>
        <view class="profile-info">
          <text class="profile-name">{{student.name}}</text>
          <text class="profile-meta">{{student.metaText}}</text>
          <text class="profile-status tag tag-green">在读</text>
        </view>
        <button class="edit-btn" wx:if="{{!editMode}}" bindtap="enterEdit">编辑</button>
      </view>

      <!-- 选项卡 -->
      <view class="tab-bar">
        <view class="tab-item {{tab === 'info' ? 'active' : ''}}" bindtap="switchTab" data-tab="info">基本信息</view>
        <view class="tab-item {{tab === 'parents' ? 'active' : ''}}" bindtap="switchTab" data-tab="parents">家长</view>
        <view class="tab-item {{tab === 'pickups' ? 'active' : ''}}" bindtap="switchTab" data-tab="pickups">接送授权</view>
        <view class="tab-item {{tab === 'health' ? 'active' : ''}}" bindtap="switchTab" data-tab="health">健康</view>
      </view>

      <!-- ======== 基本信息 ======== -->
      <view class="tab-content" wx:if="{{tab === 'info'}}">
        <block wx:if="{{!editMode}}">
          <view class="info-grid">
            <view class="info-item"><text class="info-label">性别</text><text class="info-value">{{student.genderText}}</text></view>
            <view class="info-item"><text class="info-label">年级</text><text class="info-value">{{student.gradeText}}</text></view>
            <view class="info-item"><text class="info-label">学校</text><text class="info-value">{{student.schoolNameText}}</text></view>
            <view class="info-item"><text class="info-label">班级</text><text class="info-value">{{student.schoolClassText}}</text></view>
            <view class="info-item"><text class="info-label">接送方式</text><text class="info-value">{{student.pickupMethodText}}</text></view>
            <view class="info-item"><text class="info-label">地址</text><text class="info-value">{{student.addressText}}</text></view>
            <view class="info-item"><text class="info-label">兴趣</text><text class="info-value">{{student.interestsText}}</text></view>
            <view class="info-item"><text class="info-label">性格</text><text class="info-value">{{student.personalityText}}</text></view>
            <view class="info-item"><text class="info-label">薄弱科目</text><text class="info-value">{{student.weakSubjectsText}}</text></view>
            <view class="info-item info-full"><text class="info-label">备注</text><text class="info-value">{{student.notesText}}</text></view>
          </view>

          <!-- 快捷操作 -->
          <view class="quick-actions">
            <button class="btn-secondary" bindtap="goHomework">📚 布置作业</button>
          </view>
        </block>

        <!-- 编辑模式 -->
        <block wx:if="{{editMode}}">
          <view class="edit-form">
            <view class="form-group"><text class="form-label">姓名</text><input class="input-field" value="{{editForm.name}}" bindinput="onEditField" data-field="name" /></view>
            <view class="form-group"><text class="form-label">性别</text><input class="input-field" value="{{editForm.gender}}" bindinput="onEditField" data-field="gender" /></view>
            <view class="form-group"><text class="form-label">年级</text><input class="input-field" value="{{editForm.grade}}" bindinput="onEditField" data-field="grade" /></view>
            <view class="form-group"><text class="form-label">学校</text><input class="input-field" value="{{editForm.school_name}}" bindinput="onEditField" data-field="school_name" /></view>
            <view class="form-group"><text class="form-label">班级</text><input class="input-field" value="{{editForm.school_class}}" bindinput="onEditField" data-field="school_class" /></view>
            <view class="form-group"><text class="form-label">接送方式</text><input class="input-field" value="{{editForm.pickup_method}}" bindinput="onEditField" data-field="pickup_method" /></view>
            <view class="form-group"><text class="form-label">地址</text><input class="input-field" value="{{editForm.address}}" bindinput="onEditField" data-field="address" /></view>
            <view class="form-group"><text class="form-label">兴趣</text><input class="input-field" value="{{editForm.interests}}" bindinput="onEditField" data-field="interests" /></view>
            <view class="form-group"><text class="form-label">性格</text><input class="input-field" value="{{editForm.personality}}" bindinput="onEditField" data-field="personality" /></view>
            <view class="form-group"><text class="form-label">薄弱科目</text><input class="input-field" value="{{editForm.weak_subjects}}" bindinput="onEditField" data-field="weak_subjects" /></view>
            <view class="form-group"><text class="form-label">备注</text><textarea class="input-field edit-textarea" value="{{editForm.notes}}" bindinput="onEditField" data-field="notes" /></view>
            <view class="form-actions">
              <button class="btn-secondary" bindtap="cancelEdit">取消</button>
              <button class="btn-primary" bindtap="saveEdit">保存</button>
            </view>
          </view>
        </block>
      </view>

      <!-- ======== 家长信息 ======== -->
      <view class="tab-content" wx:if="{{tab === 'parents'}}">
        <view wx:if="{{student.parents && student.parents.length > 0}}">
          <view class="parent-card" wx:for="{{student.parents}}" wx:key="id">
            <view class="parent-avatar">{{item.initial}}</view>
            <view class="parent-info">
              <text class="parent-name">{{item.name}}</text>
              <text class="parent-relation tag tag-blue">{{item.relation}}</text>
              <text class="parent-phone">{{item.phone}}</text>
            </view>
            <view class="parent-invite">
              <text class="invite-label">邀请码</text>
              <text class="invite-code" bindtap="copyInviteCode" data-code="{{item.invite_code}}">{{item.invite_code}} 📋</text>
            </view>
          </view>
        </view>
        <view class="empty-state" wx:else>
          <image class="empty-image" src="/images/empty-students-v2.png" mode="aspectFit"></image>
          <text>暂无关联家长</text>
          <text class="empty-desc">请在 PC 端后台添加家长信息</text>
        </view>
      </view>

      <!-- ======== 接送授权人 ======== -->
      <view class="tab-content" wx:if="{{tab === 'pickups'}}">
        <view class="section-actions">
          <button class="btn-secondary" bindtap="openPickupEditor">✏️ 编辑授权人</button>
        </view>
        <view wx:if="{{student.pickups && student.pickups.length > 0}}">
          <view class="pickup-card" wx:for="{{student.pickups}}" wx:key="id">
            <view class="pickup-avatar">{{item.initial}}</view>
            <view class="pickup-info">
              <text class="pickup-name">{{item.name}}</text>
              <text class="pickup-relation tag tag-green">{{item.relation}}</text>
              <text class="pickup-phone">{{item.phone}}</text>
              <text class="pickup-tag tag tag-orange" wx:if="{{item.is_default}}">默认接送人</text>
            </view>
          </view>
        </view>
        <view class="empty-state" wx:else>
          <image class="empty-image" src="/images/empty-notices-v2.png" mode="aspectFit"></image>
          <text>暂无授权接送人</text>
        </view>
      </view>

      <!-- ======== 健康信息 ======== -->
      <view class="tab-content" wx:if="{{tab === 'health'}}">
        <view class="health-card">
          <view class="health-row"><text class="health-label">食物过敏</text><text class="health-value">{{student.healthDisplay.food_allergies}}</text></view>
          <view class="health-row"><text class="health-label">药物过敏</text><text class="health-value">{{student.healthDisplay.drug_allergies}}</text></view>
          <view class="health-row"><text class="health-label">既往病史</text><text class="health-value">{{student.healthDisplay.medical_history}}</text></view>
          <view class="health-row"><text class="health-label">当前用药</text><text class="health-value">{{student.healthDisplay.current_meds}}</text></view>
          <view class="health-row"><text class="health-label">特殊备注</text><text class="health-value">{{student.healthDisplay.special_notes}}</text></view>
        </view>
        <view class="consent-section">
          <text class="consent-title">健康告知书签署状态</text>
          <view class="consent-status">
            <text wx:if="{{student.consentSigned}}" class="tag tag-green">✅ 已签署</text>
            <text wx:else class="tag tag-red">❌ 未签署</text>
            <button class="btn-secondary consent-btn" bindtap="toggleHealthConsent">
              {{student.consentButtonText}}
            </button>
          </view>
        </view>
      </view>

      <!-- ======== 接送授权人编辑弹窗 ======== -->
      <view class="modal-overlay" wx:if="{{showPickupEditor}}" bindtap="closePickupEditor">
        <view class="modal-content modal-large" catchtap="nop">
          <text class="modal-title">编辑接送授权人</text>
          <view class="pickup-edit-list">
            <view class="pickup-edit-row" wx:for="{{editPickups}}" wx:key="index">
              <view class="pickup-edit-fields">
                <input class="input-field pick-field" placeholder="姓名" value="{{item.name}}" bindinput="onPickupField" data-field="name" data-index="{{index}}" />
                <input class="input-field pick-field" placeholder="关系" value="{{item.relation}}" bindinput="onPickupField" data-field="relation" data-index="{{index}}" />
                <input class="input-field pick-field" placeholder="电话" value="{{item.phone}}" bindinput="onPickupField" data-field="phone" data-index="{{index}}" />
              </view>
              <text class="remove-btn" bindtap="removePickupRow" data-index="{{index}}" wx:if="{{editPickups.length > 1}}">删除</text>
            </view>
          </view>
          <button class="btn-secondary add-row-btn" bindtap="addPickupRow">+ 添加一行</button>
          <view class="modal-actions">
            <button class="btn-secondary modal-btn" bindtap="closePickupEditor">取消</button>
            <button class="btn-primary modal-btn" bindtap="savePickups">保存</button>
          </view>
        </view>
      </view>

    </block>

    <!-- 无数据 -->
    <view class="empty-state" wx:else>
      <text class="empty-icon">👶</text>
      <text>未找到该学生</text>
    </view>
  </block>
</view>
