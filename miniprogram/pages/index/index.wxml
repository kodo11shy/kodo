<!-- 首页（对外展示·家长信任型） -->
<view class="page">

  <!-- ====== 1. 氛围大图 + 机构名 ====== -->
  <view class="hero">
    <image class="hero-image" src="/images/banner-home-v2.png" mode="aspectFill"></image>
    <view class="hero-content">
      <image class="hero-logo" src="/images/logo-small-v2.png" mode="aspectFit"></image>
      <view class="hero-copy">
        <text class="hero-title">{{schoolName}}</text>
        <text class="hero-subtitle">{{welcomeMessage}}</text>
      </view>
    </view>
  </view>

  <!-- ====== 最新通知（温和信息条） ====== -->
  <view class="section" style="padding-top: 12rpx;">
    <view class="notice-card" wx:if="{{latestNotice}}" bindtap="tapNotice" data-id="{{latestNotice.id}}">
      <text class="notice-dot">📢</text>
      <text class="notice-text-short">最新通知：{{latestNotice.title}}</text>
      <text class="notice-more">查看 →</text>
    </view>
  </view>

  <!-- ====== 2. 家长行动区（联系方式 + 家长入口） ====== -->
  <view class="contact-section">
    <view class="contact-card">
      <view class="contact-row" wx:if="{{contactWechat}}" bindtap="copyWechat">
        <text class="contact-icon-big">💬</text>
        <view class="contact-info">
          <text class="contact-label">微信号</text>
          <text class="contact-value">{{contactWechat}}</text>
        </view>
        <text class="contact-btn">复制</text>
      </view>
      <view class="contact-divider" wx:if="{{contactWechat && contactPhone}}"></view>
      <view class="contact-row" wx:if="{{contactPhone}}" bindtap="callPhone">
        <text class="contact-icon-big">📞</text>
        <view class="contact-info">
          <text class="contact-label">联系电话</text>
          <text class="contact-value">{{contactPhone}}</text>
        </view>
        <text class="contact-btn call-btn">拨打</text>
      </view>
      <view class="contact-divider" wx:if="{{contactWechat || contactPhone}}"></view>
      <view class="contact-row parent-row" bindtap="goParentLogin">
        <text class="contact-icon-big">👨‍👩‍👧</text>
        <view class="contact-info">
          <text class="contact-label">家长入口</text>
          <text class="contact-desc">查看孩子的成长动态</text>
        </view>
        <text class="contact-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- ====== 3. 精彩瞬间 ====== -->
  <view class="section">
    <text class="section-title">📸 精彩瞬间</text>
    <swiper class="photo-swiper" autoplay interval="3000" duration="500" circular indicator-dots="{{featuredPhotos.length > 1}}">
      <swiper-item wx:for="{{featuredPhotos}}" wx:key="id">
        <view class="photo-item" bindtap="previewPhoto" data-url="{{item.url}}">
          <image class="photo-img" src="{{item.url}}" mode="widthFix"></image>
        </view>
      </swiper-item>
      <swiper-item wx:if="{{featuredPhotos.length === 0}}">
        <view class="photo-placeholder">
          <text class="placeholder-text">暂无照片</text>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- ====== 4. 关于托班 ====== -->
  <view class="section">
    <view class="about-card">
      <text class="about-card-title">🏫 关于 {{schoolName}}</text>
      <text class="about-card-desc">{{schoolName}}致力于为孩子提供温暖、专业的课后成长陪伴。
每日接送、作业辅导、餐食照护、成长记录，让家长安心工作。</text>
    </view>
  </view>

  <!-- ====== 5. 老师入口（弱化底部） ====== -->
  <view class="teacher-bottom" bindtap="goTeacherLogin">
    <text class="teacher-bottom-icon">👩‍🏫</text>
    <text class="teacher-bottom-text">老师登录</text>
    <text class="teacher-bottom-arrow">›</text>
  </view>

  <!-- ====== 6. 底部 ====== -->
  <view class="footer">
    <text class="footer-text">{{schoolName}} © 2026</text>
  </view>

  <!-- 通知详情弹窗 -->
  <view class="modal-overlay" wx:if="{{showNoticeModal}}" bindtap="closeNotice">
    <view class="notice-modal" catchtap="nop">
      <text class="notice-modal-title">{{selectedNotice.title}}</text>
      <text class="notice-modal-type" wx:if="{{selectedNotice.notice_type}}">{{selectedNotice.notice_type}}</text>
      <view class="notice-modal-divider"></view>
      <scroll-view class="notice-modal-body" scroll-y>
        <text class="notice-modal-content">{{selectedNotice.content}}</text>
      </scroll-view>
      <view class="notice-modal-footer" bindtap="closeNotice">
        <text class="notice-close-btn">知道了</text>
      </view>
    </view>
  </view>
</view>
